# ─── App ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://stratussoftware.net
NEXTAUTH_SECRET=                        # generate: openssl rand -base64 32

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/stratus_platform

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect: https://stratussoftware.net/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft / Azure AD ────────────────────────────────────────────────────
# Create at: https://portal.azure.com → App registrations
# Redirect URI: https://stratussoftware.net/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common            # or your org's tenant ID for single-tenant

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...        # or sk_test_... for dev
STRIPE_WEBHOOK_SECRET=whsec_...      # from: stripe listen --forward-to /api/stripe/webhook
STRIPE_PRICE_ID_PLATFORM=price_...  # monthly $2,000 price ID from Stripe dashboard

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PATH=/Volumes/External/stratus-storage
