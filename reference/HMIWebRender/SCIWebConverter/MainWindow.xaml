<Window x:Class="SCIWebConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SCIWebConverter"
        mc:Ignorable="d"
        Title="SCI Web Converter" Height="560" Width="900" Background="#FF2B2B2B" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="UI/Resources/Images/SCI_Web_Icon.ico">
    <Grid x:Name="contentGrid">
        <Grid x:Name="appGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="860"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="versionLabel" Content="v#.#.#" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Bottom" FontSize="12" Foreground="#FFF0F0F0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0">
                <Image HorizontalAlignment="Center" Height="120" Margin="10" VerticalAlignment="Center" Width="120" Source="UI/Resources/Images/LOGO SMALL.png"/>
                <Label Content="SCI Web Converter" HorizontalAlignment="Center" Margin="10" VerticalAlignment="Center" FontSize="36" Foreground="#FFF0F0F0"/>
            </StackPanel>

            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="55,135,55,40">

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="Graphics Path" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="graphicPathTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="310"/>
                        <Button x:Name="graphicPathButton" Margin="5,0,0,0" Width="30" Content=". . ." FontWeight="Bold" Background="#FFEEEEEE" Click="graphicPathButton_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="23,15" Orientation="Vertical">
                    <Label Content="Conversion Type" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <ComboBox Name="conversionTypeComboBox" Width="140" SelectedIndex="0" SelectionChanged="conversionTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Render"/>
                            <ComboBoxItem Content="Raddical"/>
                            <ComboBoxItem Content="ProcessBook"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="23,15" Orientation="Vertical">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" Orientation="Horizontal" >
                        <CheckBox Name="multiThreadedCheckBox" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="True"/>
                        <Label Content="Use Multithreading" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="Save Path" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="savePathTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="310"/>
                        <Button x:Name="savePathButton" Margin="5,0,0,0" Width="30" Content=". . ." FontWeight="Bold" Background="#FFEEEEEE" Click="savePathButton_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="Raddical Network Path" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="raddicalPathTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="340"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="Conversion Map Path" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="conversionMapPathTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="310"/>
                        <Button x:Name="conversionMapPathButton" Margin="5,0,0,0" Width="30" Content=". . ." FontWeight="Bold" Background="#FFEEEEEE" Click="conversionMapPathButton_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="PI Server Name" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="piServerNameTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="340"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Orientation="Vertical">
                    <Label Content="Raddical Serializer Path" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" FontSize="12" Foreground="#FFF0F0F0" Margin="0,0,0,0"/>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0" Orientation="Horizontal">
                        <TextBox x:Name="radSerializerPathTextBox" HorizontalAlignment="Left" Height="22" Margin="0,0,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="310"/>
                        <Button x:Name="radSerializerPathButton" Margin="5,0,0,0" Width="30" Content=". . ." FontWeight="Bold" Background="#FFEEEEEE" Click="RadSerializerPathButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </WrapPanel>

            <Button x:Name="ExecuteButton" Content="Execute" HorizontalAlignment="Center" Height="25" Margin="0,0,0,20" VerticalAlignment="Bottom" Width="97" Click="ExecuteButton_Click" Background="#FFEEEEEE" Loaded="ExecuteButton_Loaded"/>
            <Button x:Name="viewLogButton" Content=" > " HorizontalAlignment="Right" Margin="0,0,5,0" VerticalAlignment="Center" Width="20" Click="viewLogButton_Click" Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>
