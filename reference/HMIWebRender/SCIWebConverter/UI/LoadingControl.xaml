<UserControl x:Class="SCIWebConverter.UI.LoadingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SCIWebConverter.UI"
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600" MinWidth="200" MinHeight="200" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid x:Name="backgroundGrid" MinWidth="200" MinHeight="200">
        <Rectangle x:Name="blurRect" Fill="#FF1F1F1F" HorizontalAlignment="Stretch" MinHeight="200" Margin="0" VerticalAlignment="Stretch" MinWidth="200" Opacity=".6"/>
        <Grid x:Name="grid" Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 0, 0, 0">
            <Image x:Name="LoadingGIF" HorizontalAlignment="Center" VerticalAlignment="Center" gif:ImageBehavior.AnimatedSource="/SCIWebConverter;component/UI/Resources/Images/LoadingGIF.gif" gif:ImageBehavior.AnimateInDesignMode="True" gif:ImageBehavior.AutoStart="True" Opacity="0" Loaded="Image_Loaded"/>
        </Grid>
    </Grid>
</UserControl>
